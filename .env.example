# Database (matches docker-compose postgres service)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=ai_automation
DB_PASSWORD=ai_automation_secret
DB_DATABASE=ai_automation_db

# App
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth
JWT_SECRET=your-strong-random-secret
JWT_EXPIRATION=24h
BCRYPT_SALT_ROUNDS=12

# Encryption
# Must be a 64-character hex string (32 bytes for AES-256-GCM).
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Repositories
REPOSITORIES_BASE_PATH=/app/repos
GITHUB_API_BASE_URL=https://api.github.com
GIT_COMMAND_TIMEOUT_MS=120000

# Task Managers
TASK_MANAGER_HTTP_TIMEOUT_MS=15000
TASK_MANAGER_DEFAULT_TASK_LIMIT=100
TASK_MANAGER_MAX_TASK_LIMIT=100

# Aggregated Tasks Feed
TASKS_DEFAULT_LIMIT=100
TASKS_MAX_LIMIT=200

# API hardening
ENABLE_SWAGGER=false
SWAGGER_PATH=api/docs
THROTTLE_LIMIT=60
THROTTLE_TTL_MS=60000

# Executions
# Claude authentication for executions uses per-user OAuth token from
# `/api/settings` (`claudeOauthToken`), not ANTHROPIC_API_KEY from env.
EXECUTION_DEFAULT_TIMEOUT_MS=1800000
EXECUTION_GRACEFUL_STOP_MS=5000
EXECUTION_MAX_CONCURRENT_PER_USER=2
EXECUTION_OUTPUT_MAX_BYTES=204800
EXECUTION_GIT_AUTHOR_NAME="Automation Bot"
EXECUTION_GIT_AUTHOR_EMAIL=automation@local
EXECUTION_AUTOPR_RETRY_COUNT=3
EXECUTION_AUTOPR_RETRY_BACKOFF_MS=2000
EXECUTION_PRE_PR_CHECK_COMMAND=
DOCKER_HOST=tcp://docker-runner:2375
EXECUTION_AUTOPR_BRANCH_PREFIX=feature/ai
EXECUTION_QUEUE_DRIVER=redis
EXECUTION_QUEUE_NAME=executions
REDIS_URL=redis://redis:6379
EXECUTION_WORKER_ENABLED=false
EXECUTION_WORKER_RECOVERY_TIMEOUT_MS=900000
EXECUTION_OUTPUT_RETENTION_DAYS=30
EXECUTION_EVENTS_RETENTION_DAYS=14
EXECUTION_REPORT_RETENTION_DAYS=30
